<ee:ejb-jar xmlns:ee="http://java.sun.com/xml/ns/javaee"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
                                http://java.sun.com/xml/ns/javaee/ejb-jar_3_1.xsd"
            version="3.1">
  <ee:enterprise-beans>
    <ee:session>
      <ee:ejb-name>MyStatelessBean</ee:ejb-name>
      <ee:ejb-class>com.example.MyStatelessBean</ee:ejb-class>
      <ee:session-type>Stateless</ee:session-type>
      <ee:transaction-type>Container</ee:transaction-type>
    </ee:session>
  </ee:enterprise-beans>
</ee:ejb-jar>